@model BoardDto
@{
    ViewData["Title"] = Model.Name;
}

<script src="~/js/delete.js"></script>

<main>
    <section class="text-center">
        <h1 class="logo-text fade-in">@Model.Name</h1>
        <p class="welcome-text">@Model.Description</p>
    </section>

    @if (User.Identity.IsAuthenticated)
    {
        <section class="fade-in-up delay-200ms">
            <div class="form-container">
                <form class="comment-form" method="post" asp-action="Create" asp-controller="Topics"
                    asp-route-categoryId="@Model.Id" asp-route-categoryName="@Model.Name">
                    <div class="form-header form-group">
                        <input type="text" name="title" class="form-input" placeholder="Название" />
                    </div>
                    <div class="form-group">
                        <textarea class="comment-textarea" name="content"
                        placeholder="Комментарий. Макс. длина 15000"></textarea>
                    </div>
                    <div class="error-message" asp-validation-summary="All"></div>

                    <div class="form-footer">
                        <button type="submit" class="submit-button">Создать</button>
                    </div>
                </form>
            </div>
        </section>
    }

    <section class="topic-section fade-in-up delay-200ms">
        <div class="table-bordered">
            <ul class="navbar-nav flex-grow-1">
                @foreach (var thread in @Model.Threads)
                {
                    <li>
                        <div>
                            <a href="/@Model.ShortName/@thread.Id">@thread.Subject</a>
                            <strong>@thread.OriginalPost.AuthorName</strong>
                            <lable class="welcome-text topic-time">@thread.CreatedAt</lable>
                        </div>
                        <div>
                            <p>@thread.OriginalPost.Content</p>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </section>
</main>