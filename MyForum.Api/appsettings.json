{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "ForumDbContext": "Host=db;Port=5432;Database=myforumdb;",
    "Redis": "redis:6379,password=,abortConnect=false"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Grafana.Loki"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Serilog.Sinks.Grafana.Loki": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 31,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            {
              "key": "Application",
              "value": "MyForum"
            },
            {
              "key": "Environment",
              "value": "Production"
            }
          ],
          "propertiesAsLabels": ["Application", "Environment", "Level"]
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "MinIO": {
    "InternalEndpoint": "minio:9000",
    "PublicEndpoint": "localhost",
    "WithSSL": false,
    "BucketName": "uploads"
  },
  "FileUpload": {
    "MaxFileSize": 4194304,
    "MaxFilesPerPost": 4,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp"],
    "MaxImageWidth": 10000,
    "MaxImageHeight": 10000,
    "ThumbnailWidth": 250,
    "ThumbnailHeight": 250
  }
}
