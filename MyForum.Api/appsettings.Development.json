{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "ForumDbContext": "Host=localhost;Port=5432;Database=myforumdb;",
    "Redis": "localhost:6379,password=,abortConnect=false"
  },
"Serilog": {
    "WriteTo": [
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://localhost:3100",
          "labels": [
            {
              "key": "Application",
              "value": "MyForum"
            },
            {
              "key": "Environment",
              "value": "Development"
            }],
          "propertiesAsLabels": ["Application", "Environment"]
        }
      }
    ]
  },
  "MinIO": {
    "Endpoint": "minio:9000",
    "WithSSL": false,
    "BucketName": "uploads"
  }
}
