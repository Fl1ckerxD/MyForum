{
    "dashboard": {
        "title": "MyForum Monitoring",
        "description": "Real-time monitoring of MyForum application",
        "tags": ["aspnet", "forum", "monitoring"],
        "panels": [
        {
            "id": 1,
            "title": "HTTP Requests",
            "type": "stat",
            "targets": [
            {
                "expr": "rate(http_server_duration_seconds_count[5m])",
                "legendFormat": "Requests/sec"
            }
            ],
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
        },
        {
            "id": 2,
            "title": "Response Time (p95)",
            "type": "stat",
            "targets": [
            {
                "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_seconds_bucket[5m])) by (le))",
                "legendFormat": "95th percentile"
            }
            ],
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
            "fieldConfig": {
            "defaults": {
                "unit": "s",
                "decimals": 3
            }
            }
        },
        {
            "id": 3,
            "title": "Error Rate (5xx)",
            "type": "stat",
            "targets": [
            {
                "expr": "rate(http_server_duration_seconds_count{http_status_code=~\"5..\"}[5m]) / rate(http_server_duration_seconds_count[5m]) * 100",
                "legendFormat": "Error %"
            }
            ],
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
            "fieldConfig": {
            "defaults": {
                "unit": "percent",
                "min": 0,
                "max": 100
            }
            }
        },
        {
            "id": 4,
            "title": "Active Threads",
            "type": "stat",
            "targets": [
            {
                "expr": "count(threads_total)",
                "legendFormat": "Active threads"
            }
            ],
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
        }
        ],
        "refresh": "10s",
        "schemaVersion": 27,
        "version": 1
    }
}
